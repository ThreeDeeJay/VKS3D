; VKS3D.def — Windows DLL export definition
;
; Exports exactly the three symbols required by the Vulkan ICD interface.
; Using a .def file guarantees undecorated export names on both x64 and
; x86 (32-bit __stdcall would otherwise mangle names as _name@N).
;
; NOTE: The LIBRARY directive is intentionally omitted. Including it would
; hardcode a DLL name that conflicts with the actual outputs VKS3D_x64.dll
; and VKS3D_x86.dll, producing LNK4070. The linker uses the real output
; filename when LIBRARY is absent.
;
; Additional export: vks3d_internal_marker
;   Used by the self-detection logic in stereo.c to prevent VKS3D from
;   accidentally loading itself as the "real" ICD.

EXPORTS
    vk_icdNegotiateLoaderICDInterfaceVersion
    vk_icdGetInstanceProcAddr
    vk_icdGetPhysicalDeviceProcAddr
    ; Public vkGetDeviceProcAddr — exported so the loader and tools can find
    ; device-level functions directly without going through the ICD interface.
    vkGetDeviceProcAddr
    ; Device-level intercept functions exported as named symbols.
    ; The loader uses vk_icdGetInstanceProcAddr to get these, but exporting
    ; them here ensures tools like vks3d_diag can verify they are present and
    ; provides compatibility with loaders that use GetProcAddress fallback.
    vkCreateSwapchainKHR
    vkDestroySwapchainKHR
    vkGetSwapchainImagesKHR
    vkAcquireNextImageKHR
    vkQueuePresentKHR
    vkCreateRenderPass
    vkCreateRenderPass2KHR
    vkCreateShaderModule
    vkDestroyShaderModule
    vkCreateImageView
    ; Internal marker used by self-detection (prevents VKS3D loading itself)
    vks3d_internal_marker
